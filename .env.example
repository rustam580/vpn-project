YOOKASSA_POLL_SECONDS=60
PAYMENT_PROCESSING_REQUEUE_SECONDS=600
RENEWAL_ALERTS_ENABLED=true
RENEWAL_ALERT_INTERVAL_SEC=300
RENEWAL_REMINDER_HOURS=72,24,6
RENEWAL_EXPIRED_ALERT_ENABLED=true
ADMIN_ALERTS_ENABLED=true
ADMIN_ALERT_COOLDOWN_SEC=900
