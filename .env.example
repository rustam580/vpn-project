SUB_MIGRATION_REMINDER_BATCH=20
SUBSCRIPTION_HITS_RETENTION_DAYS=60
MARZBAN_SYNC_AUDIT_ENABLED=true
MARZBAN_SYNC_AUDIT_INTERVAL_SEC=21600
MARZBAN_SYNC_AUDIT_LIMIT=100
MARZBAN_SYNC_AUDIT_SHOW=8
