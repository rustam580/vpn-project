+func TestWBStreamIssueUsesConfiguredAccessToken(t *testing.T) {
+	const configuredToken = "configured-access"
+	var guestRegisterCalled bool
+	mux := http.NewServeMux()
+	mux.HandleFunc("POST /auth/api/v1/auth/user/guest-register", func(w http.ResponseWriter, _ *http.Request) {
+		guestRegisterCalled = true
+		_ = json.NewEncoder(w).Encode(guestRegisterResponse{AccessToken: testAccessToken}) //nolint:gosec
+	})
+	mux.HandleFunc("POST /api-room/api/v1/room/"+testRoomID+"/join", func(w http.ResponseWriter, r *http.Request) {
+		if r.Header.Get("Authorization") != "Bearer "+configuredToken {
+			t.Fatalf("join auth = %q", r.Header.Get("Authorization"))
+		}
+		w.WriteHeader(http.StatusOK)
+	})
+	mux.HandleFunc("GET /api-room-manager/v2/room/"+testRoomID+"/connection-details",
+		func(w http.ResponseWriter, r *http.Request) {
+			if r.Header.Get("Authorization") != "Bearer "+configuredToken {
+				t.Fatalf("token auth = %q", r.Header.Get("Authorization"))
+			}
+			_ = json.NewEncoder(w).Encode(tokenResponse{RoomToken: testToken})
+		})
+
+	withWBAPIServer(t, mux)
+	t.Setenv(accessTokenEnv, configuredToken)
+	t.Setenv(accessTokenFileEnv, "")
+
+	creds, err := Provider{}.Issue(context.Background(), auth.Config{
+		RoomURL: testRoomID,
+		Name:    testPeerName,
+	})
+	if err != nil {
+		t.Fatalf("Issue() error = %v", err)
+	}
+	if guestRegisterCalled {
+		t.Fatal("Issue() registered a guest despite configured access token")
+	}
+	if creds.Token != testToken {
+		t.Fatalf("creds.Token = %q", creds.Token)
+	}
+}
+
+func TestConfiguredAccessTokenReadsFile(t *testing.T) {
+	path := filepath.Join(t.TempDir(), "wbstream-token")
+	if err := os.WriteFile(path, []byte(" file-token \n"), 0o600); err != nil {
+		t.Fatalf("WriteFile() error = %v", err)
+	}
+	t.Setenv(accessTokenEnv, "")
+	t.Setenv(accessTokenFileEnv, path)
+
+	token, err := configuredAccessToken()
+	if err != nil {
+		t.Fatalf("configuredAccessToken() error = %v", err)
+	}
+	if token != "file-token" {
+		t.Fatalf("configuredAccessToken() = %q", token)
+	}
+}
